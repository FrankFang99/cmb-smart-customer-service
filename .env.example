# MiniMax LLM API 配置 (项目本地, 不进 git, 不进系统环境)
# 复制 .env.example 为 .env 后填入真 token

# MiniMax API key (从 MiniMax 开放平台 https://platform.MiniMax.io/ 控制台 → API Keys 复制)
MINIMAX_API_KEY=sk-api-PUT-YOUR-KEY-HERE

# 自定义 baseURL (一般不动, 除非 MiniMax 改路径)
# MINIMAX_BASE_URL=https://agent.minimaxi.com/mavis/api/v1/llm/v1

# 自定义模型 (一般不动)
# MINIMAX_MODEL=MiniMax-M3
